ORPHAN_NODE_ID = "EXTERNAL_OR_MISSING_ISSUER"

class Status:
    def __init__(self, name: str, icon: str, color: str, translate: bool = True):
        self.NAME: str = _(name) if translate else name
        self.ICON: str = icon
        self.COLOR: str = color

    def log(self, message: str, detail: str = "", label: Optional[str] = None, extra_icon: str = "  ") -> None:
        display_label = label if label else self.NAME
        reset = "\033[0m"
        v_line = "\u2502"
        sep = f"{reset}{v_line}{self.COLOR}"

        icon_str = extra_icon.strip()
        if icon_str:
            formatted_icon = f" {icon_str} "
        else:
            formatted_icon = "    "

        prefix = "{}{} {:<12} {} {} {} {:<40} {} ".format(
            self.COLOR,
            self.ICON,
            display_label,
            sep,
            formatted_icon,
            sep,
            message[:40],
            sep
        )

        sys.stderr.write("{}{}{}\n".format(prefix, detail, reset))

RED, GREEN, YELLOW, CYAN, MAGENTA, BLUE = "\033[91m", "\033[92m", "\033[93m", "\033[96m", "\033[95m", "\033[94m"

ERROR = Status("ERROR", "\U0000274C", RED)                              # ❌
OK = Status("OK", "\U00002705", GREEN)                                  # ✅
WARNING = Status("WARNING", "\U000023F3", YELLOW)                       # ⏳
MISSING = Status("MISSING", "\U00002753", MAGENTA, translate=False)     # ❓
COLLISION = Status("COLLISION", "\U0001F46F", CYAN, translate=False)    # 👯
INFO = Status("INFO", "\U0001F535", BLUE)                               # 🔵
SYSTEM = Status("SYSTEM", "\U0001F4BB", BLUE, translate=False)          # 💻

class Certificate(BaseModel):
    if PYDANTIC_AVAILABLE:
        common_name: str = Field(..., alias="commonName")
        file_name: str = Field("", alias="fileName")
        sha256_hash: str = Field("", alias="sha256Hash")
        is_valid: bool = Field(False, alias="isValid")
        is_expiring_soon: bool = Field(False, alias="isExpiringSoon")
        expiry_date: Union[datetime, str] = Field("1970-01-01", alias="expiryDate")
        is_collision: bool = Field(False, alias="isCollision")
        is_system_cert: bool = Field(False, alias="isSystemCert")
        children: Optional[List[Any]] = None

        if PYDANTIC_V2:
            model_config = ConfigDict(populate_by_name=True, from_attributes=True)
            @model_validator(mode='before')
            @classmethod
            def validate_node(cls, data: Dict[str, Any]) -> Dict[str, Any]:
                return cls._apply_special_logic(data)
        else:
            class Config:
                allow_population_by_field_name = True

            @model_validator(pre=True)
            @classmethod
            def validate_node(cls, values: Dict[str, Any]) -> Dict[str, Any]:
                return cls._apply_special_logic(values)

        @staticmethod
        def _apply_special_logic(data: Dict[str, Any]) -> Dict[str, Any]:
            cn = data.get("common_name") or data.get("commonName")
            if cn == ORPHAN_NODE_ID:
                special = {
                    "is_valid": False, "isValid": False,
                    "is_expiring_soon": False, "isExpiringSoon": False,
                    "expiry_date": datetime(1970, 1, 1, tzinfo=timezone.utc),
                    "expiryDate": datetime(1970, 1, 1, tzinfo=timezone.utc)
                }
                if isinstance(data, dict): data.update(special)
            return data
    else:
        def __init__(self, common_name=None, is_valid=False, is_expiring_soon=False, expiry_date="1970-01-01", is_collision=False, is_system=False, file_name="", sha256_hash="", children=None, **kwargs):
            self.common_name = common_name
            self.file_name = file_name
            self.sha256_hash = sha256_hash
            self.is_valid = is_valid
            self.is_expiring_soon = is_expiring_soon
            self.expiry_date = expiry_date
            self.is_collision = is_collision
            self.is_system_cert = is_system
            self.children = children or []

            mapping = {
                "commonName": "common_name",
                "isValid": "is_valid",
                "isExpiringSoon": "is_expiring_soon",
                "expiryDate": "expiry_date",
                "isCollision": "is_collision",
                "fileName": "file_name",
                "sha256Hash": "sha256_hash"
            }

            for k, v in kwargs.items():
                setattr(self, mapping.get(k, k), v)

            if self.common_name == ORPHAN_NODE_ID:
                self.is_valid = False
                self.is_expiring_soon = False
                self.expiry_date = datetime(1970, 1, 1, tzinfo=timezone.utc)

        def model_dump(self):
            obj = {
                "commonName": self.common_name,
                "fileName": self.file_name,
                "sha256Hash": self.sha256_hash,
                "isValid": self.is_valid,
                "isExpiringSoon": self.is_expiring_soon,
                "expiryDate": self.expiry_date.isoformat() if isinstance(self.expiry_date, datetime) else self.expiry_date,
                "isCollision": self.is_collision,
                "isSystemCert": self.is_system_cert
            }
            if getattr(self, "children", None): obj["children"] = [c.model_dump() for c in self.children]
            return obj

class BaseRenderer(ABC):
    @abstractmethod
    def render(self, tree_data: List[Union[Certificate, Any]]) -> str:
        pass

class TextRenderer(BaseRenderer):
    def render(self, tree_data: List[Union[Certificate, Any]], include_system: bool = False) -> str:
        output = ["", _("Certificate Hierarchy:")]
        self.include_system = include_system
        output.append(self._recursive_render(tree_data))
        return "\n".join(output)

    def _recursive_render(self, nodes: List[Union[Certificate, Any]], indent: str = "") -> str:
        lines = []
        for i, n in enumerate(nodes):
            raw_name = getattr(n, "common_name", _("Unknown"))
            if raw_name == ORPHAN_NODE_ID:
                if getattr(self, "include_system", False):
                    name = _("UNTRUSTED (NOT IN YAML OR SYSTEM)")
                else:
                    name = _("EXTERNAL ISSUER / MISSING ROOT")
            else:
                name = raw_name
            is_valid = getattr(n, "is_valid", None)
            is_soon = getattr(n, "is_expiring_soon", None)
            expiry = getattr(n, "expiry_date", None)
            is_collision = getattr(n, "is_collision", False)
            is_system = getattr(n, "is_system_cert", False)
            children = getattr(n, "children", None)

            icons = []
            if raw_name == ORPHAN_NODE_ID:
                icons.append(MISSING.ICON)
            else:
                st = ERROR if not is_valid else (WARNING if is_soon else OK)
                icons.append(st.ICON)
                if is_collision:
                    icons.append(COLLISION.ICON)
                if is_system:
                    icons.append(SYSTEM.ICON)

            icon_str = "".join(["[{}]".format(ico) for ico in icons])
            date_str = ""
            if expiry and raw_name != ORPHAN_NODE_ID:
                ds = expiry.strftime('%Y-%m-%d') if isinstance(expiry, datetime) else str(expiry)[:10]
                date_str = " ({})".format(ds)

            connector = "└── " if i == len(nodes) - 1 else "├── "
            lines.append("{}{}{} {} {}".format(indent, connector, name, icon_str, date_str))

            if children:
                new_indent = indent + ("    " if i == len(nodes) - 1 else "│   ")
                lines.append(self._recursive_render(children, new_indent))
        return "\n".join(lines)

class JsonRenderer(BaseRenderer):
    def render(self, tree_data: List[Union[Certificate, Any]]) -> str:
        if PYDANTIC_AVAILABLE and PYDANTIC_V2 and TypeAdapter:
            ta = TypeAdapter(List[Certificate])
            raw_data = ta.dump_python(tree_data, mode='json', by_alias=True, exclude_none=True)
        else:
            raw_data = [c.model_dump() if hasattr(c, 'model_dump') else c.dict(by_alias=True) for c in tree_data]

        clean_data = self._filter_fields(raw_data)
        return json.dumps(clean_data, indent=2, default=lambda o: o.isoformat() if isinstance(o, datetime) else str(o))

    def _filter_fields(self, data: Any) -> Any:
        if isinstance(data, list):
            return [self._filter_fields(item) for item in data]
        
        if isinstance(data, dict):
            allowed_fields = {"commonName", "isValid", "isExpiringSoon", "expiryDate", "children"}
            
            new_dict = {}
            for key, value in data.items():
                if key in allowed_fields:
                    if key == "children" and value is not None:
                        new_dict[key] = self._filter_fields(value)
                    else:
                        new_dict[key] = value
            return new_dict
        
        return data    
class StatusRenderer(BaseRenderer):
    STATUS_MAP = {
        "VALID": {"code": 0, "label": "VALID"},
        "EXPIRING_SOON": {"code": 1, "label": "EXPIRING_SOON"},
        "UNTRUSTED": {"code": 2, "label": "UNTRUSTED"},
        "EXPIRED": {"code": 3, "label": "EXPIRED"},
        "INVALID": {"code": 4, "label": "INVALID"}
    }

    def render(self, tree_data: List[Certificate]) -> str:
        flat_list = self._flatten_tree(tree_data)
        status_output = []

        for cert in flat_list:
            if cert.common_name == ORPHAN_NODE_ID:
                continue

            status_info = self._get_status_info(cert, tree_data)

            status_output.append({
                "fileName": getattr(cert, "file_name", "unknown"),
                "commonName": cert.common_name,
                "statusCode": status_info["code"],
                "statusLabel": status_info["label"],
                "expiryDate": cert.expiry_date.isoformat() if hasattr(cert.expiry_date, "isoformat") else str(cert.expiry_date)
            })

        return json.dumps(status_output, indent=2)

    def _get_status_info(self, cert: Certificate, tree_data) -> dict:
        if not cert.is_valid:
            return self.STATUS_MAP["EXPIRED"]

        if self._is_untrusted(cert, tree_data):
            return self.STATUS_MAP["UNTRUSTED"]

        if cert.is_expiring_soon:
            return self.STATUS_MAP["EXPIRING_SOON"]
        
        return self.STATUS_MAP["VALID"]
        
    def _is_untrusted(self, cert: Certificate, tree_data) -> bool:
        for root in tree_data:
            if getattr(root, "common_name", "") == ORPHAN_NODE_ID:
                if self._find_in_children(cert, root.children or []):
                    return True
        return False

    def _find_in_children(self, target, children) -> bool:
        target_hash = getattr(target, "sha256_hash", "")
        for child in children:
            if getattr(child, "sha256_hash", "") == target_hash:
                return True
            if child.children and self._find_in_children(target, child.children):
                return True
        return False

    def _flatten_tree(self, nodes: List[Certificate], seen_hashes: set = None) -> List[Certificate]:
        if seen_hashes is None:
            seen_hashes = set()
        
        flat = []
        for n in nodes:
            cert_hash = getattr(n, "sha256_hash", n.common_name)
            if cert_hash not in seen_hashes:
                flat.append(n)
                seen_hashes.add(cert_hash)
            
            if n.children:
                flat.extend(self._flatten_tree(n.children, seen_hashes))
        return flat

class TrustStoreRenderer:
    def __init__(self):
        self._renderers: Dict[str, BaseRenderer] = {
            "text": TextRenderer(),
            "json": JsonRenderer(),
            "status": StatusRenderer()
        }

    def render(self, tree_data: List[Union[Certificate, Any]], format_type: str, include_system: bool = False) -> str:
        renderer = self._renderers.get(format_type)
        if not renderer:
            raise ValueError(_("Unknown format: {}").format(format_type))
        
        if isinstance(renderer, TextRenderer):
            return renderer.render(tree_data, include_system)
        
        return renderer.render(tree_data)

class TrustStoreAnalyzer:
    def __init__(self, yaml_path: Optional[str] = None, debug: bool = False, include_system: bool = False, threshold_days: int = 30):
        self.yaml_path: Path = Path(yaml_path) if yaml_path else None
        self.debug: bool = debug
        self.include_system: bool = include_system
        self.threshold_days: int = threshold_days
        self.cert_data: Dict[str, Certificate] = {}
        self.parent_map: Dict[str, str] = {}
        self.name_count: Dict[str, int] = defaultdict(int)
        self.seen_hashes: Set[str] = set()

    def _get_system_ca_paths(self) -> List[Path]:
        os_type = platform.system()
        paths = []

        if os_type == "Linux":
            common_paths = [
                "/etc/pki/tls/certs/ca-bundle.crt",                 # Fedora/RHEL
                "/etc/ssl/certs/ca-certificates.crt",               # Debian/Ubuntu
                "/etc/ca-certificates/extracted/tls-ca-bundle.pem"  # Arch/SuSE
            ]

            for p in common_paths:
                if Path(p).exists():
                    paths.append(Path(p))
                    break

        elif os_type == "Darwin":                                   # macOS
            p = Path("/etc/ssl/cert.pem")
            if p.exists(): paths.append(p)

        return paths

    def _load_certs_from_file(self, path: Path) -> List[Dict]:
        certs_found = []
        try:
            with open(str(path), "rb") as f:
                content = f.read()

            import re
            cert_blocks = re.findall(b"-----BEGIN (?:TRUSTED )?CERTIFICATE-----.*?-----END (?:TRUSTED )?CERTIFICATE-----", content, re.DOTALL)

            for block in cert_blocks:
                c_hash = hashlib.sha256(block).hexdigest()
                if c_hash in self.seen_hashes:
                    continue

                self.seen_hashes.add(c_hash)

                try:
                    clean_block = block.replace(b"TRUSTED CERTIFICATE", b"CERTIFICATE")
                    cert = x509.load_pem_x509_certificate(clean_block, default_backend())

                    certs_found.append({
                        "cert": cert,
                        "path": path,
                        "hash": c_hash
                    })

                except Exception as e:
                    if self.debug:
                        ERROR.log(path.name, _("Inner parse error: {e}"))

        except Exception as e:
            if self.debug: ERROR.log(path.name, str(e), label=_("READ_ERROR"))

        return certs_found

    def _get_extension_value(self, cert: x509.Certificate, oid: x509.ObjectIdentifier) -> Optional[str]:
        try:
            ext = cert.extensions.get_extension_for_oid(oid)
            if oid == x509.ExtensionOID.SUBJECT_KEY_IDENTIFIER:
                return ext.value.digest.hex()
            elif oid == x509.ExtensionOID.AUTHORITY_KEY_IDENTIFIER:
                return ext.value.key_identifier.hex() if ext.value.key_identifier else None
        except x509.ExtensionNotFound:
            return None
        return None

    def _get_common_name(self, cert) -> str:
        try:
            names = cert.subject.get_attributes_for_oid(x509.NameOID.COMMON_NAME)
            return names[0].value if names else _("Unknown")
        except Exception:
            return _("Unknown")

    def analyze(self) -> List[Union[Certificate, Any]]:
        _("READ_ERROR"); _("UNTRUSTED")

        yaml_paths = self._get_paths_from_yaml() if self.yaml_path else []
        system_paths = self._get_system_ca_paths() if self.include_system else []

        all_certs_to_load = []

        for p in yaml_paths:
            all_certs_to_load.append((p, False))

        if self.include_system:
            for p in system_paths:
                all_certs_to_load.append((p, True))

        if self.debug:
            INFO.log(_("Configuration loaded"), _("Processing {count} certificate paths").format(count=len(yaml_paths)))

        raw_certs_with_meta = []
        for path, is_system in all_certs_to_load:
            certs = self._load_certs_from_file(path)
            for c in certs:
                c["is_system"] = is_system
                raw_certs_with_meta.append(c)

        if self.include_system and platform.system() == "Windows":
            import ssl
            for store_name in ["ROOT", "CA"]:
                for cert_der in ssl.enum_certificates(store_name):
                    try:
                        cert = x509.load_der_x509_certificate(cert_der[0], default_backend())
                        c_hash = hashlib.sha256(cert_der[0]).hexdigest()
                        if c_hash not in self.seen_hashes:
                            self.seen_hashes.add(c_hash)
                            raw_certs_with_meta.append({
                                "cert": cert,
                                "path": Path(f"Windows-{store_name}-Store"),
                                "hash": c_hash
                            })
                            cn = self._get_common_name(cert)
                            self.name_count[cn] += 1

                    except Exception as e:
                        if self.debug: print(f"Windows Cert Error: {e}")                         

        for item in raw_certs_with_meta:
            cert = item["cert"]
            path = item["path"]
            c_hash = item["hash"]
            is_system = item["is_system"]

            ski = self._get_extension_value(cert, x509.ExtensionOID.SUBJECT_KEY_IDENTIFIER)
            aki = self._get_extension_value(cert, x509.ExtensionOID.AUTHORITY_KEY_IDENTIFIER)
            cn = self._get_common_name(cert)

            self.name_count[cn] += 1

            cert_id = ski if ski else hashlib.md5(cert.subject.public_bytes()).hexdigest()

            try:
                expiry = cert.not_valid_after_utc
                start = cert.not_valid_before_utc
            except AttributeError:
                expiry = cert.not_valid_after.replace(tzinfo=timezone.utc)
                start = cert.not_valid_before.replace(tzinfo=timezone.utc)

            now = datetime.now(timezone.utc)
            is_valid = start <= now <= expiry
            is_soon = now <= expiry <= (now + timedelta(days=self.threshold_days))

            if aki and aki != cert_id:
                self.parent_map[cert_id] = aki
            elif cert.subject != cert.issuer:
                self.parent_map[cert_id] = ORPHAN_NODE_ID

            cert_fields = {
                "commonName": cn,
                "fileName": path.name,
                "sha256Hash": c_hash,
                "isValid": is_valid,
                "isExpiringSoon": is_soon,
                "expiryDate": expiry,
                "isCollision": False,
                "isSystemCert": is_system
            }

            if PYDANTIC_AVAILABLE:
                self.cert_data[cert_id] = Certificate(**cert_fields)
            else:
                self.cert_data[cert_id] = Certificate(
                    common_name = cn,
                    file_name = path.name,
                    sha256_hash = c_hash,
                    is_valid=is_valid,
                    is_expiring_soon=is_soon,
                    expiry_date=expiry,
                    is_collision=False,
                    is_system = is_system
                )

        target_skis = {ski for ski, cert in self.cert_data.items() if not cert.is_system_cert}
        relevant_skis = set()
        for ski in target_skis:
            curr = ski
            while curr and curr in self.cert_data:
                relevant_skis.add(curr)
                curr = self.parent_map.get(curr)


        if self.debug:
            for ski in sorted(relevant_skis):
                cert_obj = self.cert_data[ski]
                is_coll = self.name_count[cert_obj.common_name] > 1
                cert_obj.is_collision = is_coll

                st = ERROR if not cert_obj.is_valid else (WARNING if cert_obj.is_expiring_soon else OK)
                if cert_obj.is_system_cert:
                    st = SYSTEM
                
                coll_marker = COLLISION.ICON if is_coll else "  "
                log_msg = f"{cert_obj.common_name} (SKI: {ski[:8]})" if is_coll else cert_obj.common_name
                st.log(log_msg, cert_obj.expiry_date.strftime("%Y-%m-%d %H:%M"), extra_icon=coll_marker)

            known_skis = set(self.cert_data.keys())
            for c_id in relevant_skis:
                aki = self.parent_map.get(c_id)
                if aki and aki not in known_skis and aki != ORPHAN_NODE_ID:
                    MISSING.log(f"AKI: {aki[:8]}", 
                                f"{_('Missing issuer for')}: {self.cert_data[c_id].common_name}", 
                                label=_("UNTRUSTED"))

        return self._build_tree()

    def _create_virtual_node(self, name: str) -> Union['Certificate', Any]:
        epoch_date = datetime(1970, 1, 1, tzinfo=timezone.utc)

        if PYDANTIC_AVAILABLE:
            return Certificate(
                commonName=name,
                isValid=False,
                isExpiringSoon=False,
                expiryDate=epoch_date,
                isCollision=False,
                isSystemCert=False
            )
        else:
            return Certificate(
                name,       # commonName
                False,      # isValid
                False,      # isExpiringSoon
                epoch_date, # expiryDate
                False,      # isCollision
                False       # isSystemCert
            )

    def _build_tree(self) -> List[Union[Certificate, Any]]:
        target_skis = {
            ski for ski, cert in self.cert_data.items() if not cert.is_system_cert
        }

        relevant_skis = set()
        for ski in target_skis:
            current = ski
            while current:
                relevant_skis.add(current)
                parent_ski = self.parent_map.get(current)
                if not parent_ski or parent_ski == ORPHAN_NODE_ID or parent_ski not in self.cert_data:
                    break
                current = parent_ski

        roots = [ski for ski in relevant_skis if self.parent_map.get(ski) not in relevant_skis]

        processed_skis = set()
        children_by_parent = defaultdict(list)
        for ski, p_ski in self.parent_map.items():
            if ski in relevant_skis:
                children_by_parent[p_ski].append(ski)

        def node_to_obj(ski: str) -> Union[Certificate, Any]:
            processed_skis.add(ski)
            cert = self.cert_data[ski]
            child_skis = [c for c in children_by_parent.get(ski, []) if c in relevant_skis]
            
            if child_skis:
                cert.children = [node_to_obj(c_ski) for c_ski in sorted(child_skis, key=lambda x: self.cert_data[x].common_name)]
            else:
                cert.children = None
            
            return cert
        
        trusted_tree = []
        orphan_skis = []

        for r_ski in roots:
            parent_ski = self.parent_map.get(r_ski)
            if parent_ski == ORPHAN_NODE_ID or (parent_ski and parent_ski not in self.cert_data):
                orphan_skis.append(r_ski)
            else:
                trusted_tree.append(node_to_obj(r_ski))

        trusted_tree.sort(key=lambda x: x.common_name)

        if orphan_skis:
            ext_node = self._create_virtual_node(ORPHAN_NODE_ID)
            ext_node.children = [node_to_obj(o_ski) for o_ski in sorted(orphan_skis, key=lambda x: self.cert_data[x].common_name)]
            trusted_tree.append(ext_node)

        return trusted_tree

    def _get_paths_from_yaml(self) -> List[Path]:
        with open(str(self.yaml_path), "r") as f:
            data = yaml.safe_load(f)
        env = data.get("env", "acc")
        ext = data.get("certificate_file_extension", ".crt")
        paths = []

        for ts in data.get("truststores", []):
            src = ts.get("cert_src_dir", "").replace("{{ env }}", env)
            for link in ts.get("cert_chain", []):
                if link.get("link"):
                    p = Path(os.path.abspath(os.path.join(src, link["link"] + ext)))
                    if p not in paths: paths.append(p)
        return paths

def main() -> None:
    _("ERROR"); _("WARNING"); _("OK"); _("INFO")

    def valid_file(path_str: str) -> Path:
        path = Path(path_str)
        if not path.is_file():
            raise argparse.ArgumentTypeError(_("File '{path}' does not exist.").format(path=path_str))
        return path

    parser = argparse.ArgumentParser(
        description=_("Analyze certificate truststores and visualize the chain hierarchy."),
        epilog=_("Compatible with Python 3.6+"),
        add_help=False
    )
    parser.add_argument("input", type=valid_file, help=_("Path to the YAML file"))
    parser.add_argument("-h", "--help", action="help", default=argparse.SUPPRESS, help=_("Show this help message and exit"))
    parser.add_argument("-f", "--format", choices=["json", "text", "status"], default="json", help=_("Output format"))
    parser.add_argument("-d", "--debug", action="store_true", default=False, help=_("Show debug info"))
    parser.add_argument("-s", "--system", action="store_true", default=False, help=_("Incorporate system truststore"))
    parser.add_argument("-t", "--threshold", type=int, default=30, help=_("Expiration threshold in days (default: 30)"))

    args = parser.parse_args()

    analyzer = TrustStoreAnalyzer(args.input, args.debug, args.system, args.threshold)
    tree_data = analyzer.analyze()

    try:
        renderer = TrustStoreRenderer()
        output = renderer.render(tree_data, args.format, include_system=args.system)
        print(output)
    except Exception as e:
        ERROR.log(_("Rendering failed"), str(e))
        sys.exit(1)

if __name__ == "__main__":
    main()
