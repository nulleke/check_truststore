PYDANTIC_AVAILABLE = False
PYDANTIC_V2 = False
try:
    from pydantic import BaseModel, Field
    try:
        from pydantic import model_validator, TypeAdapter, ConfigDict
        PYDANTIC_V2 = True
    except ImportError:
        from pydantic import root_validator as model_validator
        TypeAdapter = None
        PYDANTIC_V2 = False
